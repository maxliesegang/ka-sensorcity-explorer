{
  "name": "ka-sensorcity-explorer",
  "version": "1.0.0",
  "private": true,
  "description": "A minimal data explorer for the City of Karlsruhe SensorCity ArcGIS API.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "capture:demo": "node scripts/capture-demo.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@kern-ux-annex/kern-react-kit": "^2.40.0",
    "d3-delaunay": "^6.0.4",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/d3-delaunay": "^6.0.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
